
# Any OpenAI-compatible endpoint works: OpenAI, Groq, Together, Ollama, etc.
TOOLHIVE_PROVIDER_API_KEY=sk-...
TOOLHIVE_PROVIDER_MODEL=gpt-4o-mini
TOOLHIVE_PROVIDER_BASE_URL=https://api.openai.com/v1

# TOOLHIVE_REGISTRY_DB=registry.db
# TOOLHIVE_FEEDBACK_DB=feedback.db
# TOOLHIVE_STATE_DB=scheduler_state.db

#Base model for GPU-backed LoRA inference 
# Ignored when TOOLHIVE_PROVIDER_API_KEY is set.
TOOLHIVE_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct

#Critic / verifier
TOOLHIVE_CRITIC_ENABLED=1

#Webhook alerting
# TOOLHIVE_ALERT_WEBHOOK=https://hooks.slack.com/services/...
# TOOLHIVE_ALERT_THRESHOLD=0.20
